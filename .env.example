# Copy this file to .env and fill in your key (never commit .env)
# Local dev: npm run dev  ·  Production: npm run build && npm start
# Keys: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Optional: max reply length (default 2048). Lower if OpenRouter reports credit / max_tokens errors.
# OPENROUTER_MAX_TOKENS=1024
# Optional: shown on OpenRouter dashboard
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=SIOLENCE
